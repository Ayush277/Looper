# ── Core ────────────────────────────────────────────────────────────────
# Environment: dev | prod
LOOPJOB_ENV=dev
LOG_LEVEL=INFO

# ── Database ────────────────────────────────────────────────────────────
# Dev default (no Docker needed): SQLite file in backend/.
# Prod / Docker: postgresql+asyncpg://loopjob:loopjob@postgres:5432/loopjob
DATABASE_URL=sqlite+aiosqlite:///./loopjob.db

# ── Redis (broker, cache, locks) — required for worker/scheduler ────────
REDIS_URL=redis://localhost:6379/0

# ── Secrets (never stored in DB; all optional in dev) ───────────────────
# Embeddings: leave empty to use the local sentence-transformers fallback
OPENAI_API_KEY=
# Email: leave empty to print digests to the console (ConsoleNotifier)
RESEND_API_KEY=
# Global discovery sources (docs/15)
JSEARCH_API_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ── Frontend ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
